SELECT j.ID, j.Nombre, j.Apellido, j.Nacionalidad, jp.JugadorID, jp.PosicionID
FROM Jugador j
LEFT JOIN JugadorPosicion jp ON j.ID = jp.JugadorID
WHERE jp.JugadorID IS NULL;

SELECT e.ID, e.Nombre, COUNT(j.ID) AS CantidadJugadores
FROM Equipo e
LEFT JOIN Jugador j ON e.ID = j.EquipoID
GROUP BY e.ID, e.Nombre
ORDER BY CantidadJugadores DESC
LIMIT 1;

SELECT l.ID, l.Nombre AS Liga, COUNT(j.ID) AS CantidadJugadores
FROM Liga l
LEFT JOIN Equipo e ON l.ID = e.LigaID
LEFT JOIN Jugador j ON e.ID = j.EquipoID
GROUP BY l.ID, l.Nombre
ORDER BY CantidadJugadores DESC;

SELECT e.ID, e.Nombre, COUNT(j.ID) AS CantidadJugadores
FROM Equipo e
LEFT JOIN Jugador j ON e.ID = j.EquipoID
GROUP BY e.ID, e.Nombre
HAVING COUNT(j.ID) > (
    SELECT AVG(cantidad_jugadores)
    FROM (
        SELECT COUNT(j2.ID) AS cantidad_jugadores
        FROM Equipo e2
        LEFT JOIN Jugador j2 ON e2.ID = j2.EquipoID
        GROUP BY e2.ID
    ) t
);

SELECT en.ID, en.Nombre, en.Apellido, en.Nacionalidad,
       eq.Nombre AS Equipo, l.Pais AS PaisLiga
FROM Entrenador en
JOIN Equipo eq ON en.EquipoID = eq.ID
JOIN Liga l ON eq.LigaID = l.ID
WHERE en.Nacionalidad <> l.Pais;

SELECT j.ID, j.Nombre, j.Apellido, j.Nacionalidad,
       eq.Nombre AS Equipo, en.Nombre AS NombreEntrenador, en.Apellido AS ApellidoEntrenador
FROM Jugador j
JOIN Equipo eq ON j.EquipoID = eq.ID
JOIN Entrenador en ON en.EquipoID = eq.ID
WHERE j.Nacionalidad = en.Nacionalidad;

SELECT p.ID, p.Nombre, COUNT(jp.JugadorID) AS CantidadJugadores
FROM Posicion p
JOIN JugadorPosicion jp ON p.ID = jp.PosicionID
GROUP BY p.ID, p.Nombre
ORDER BY CantidadJugadores DESC
LIMIT 1;

SELECT p.ID, p.Nombre, COUNT(jp.JugadorID) AS CantidadJugadores
FROM Posicion p
LEFT JOIN JugadorPosicion jp ON p.ID = jp.PosicionID
GROUP BY p.ID, p.Nombre
ORDER BY CantidadJugadores ASC
LIMIT 1;

SELECT en.ID, en.Nombre, en.Apellido, en.Nacionalidad, eq.Nombre AS Equipo
FROM Entrenador en
JOIN Equipo eq ON en.EquipoID = eq.ID
WHERE NOT EXISTS (
    SELECT 1
    FROM Jugador j
    WHERE j.EquipoID = eq.ID
      AND j.Nacionalidad = en.Nacionalidad
);

SELECT DISTINCT
    j.ID,
    j.Nombre,
    j.Apellido,
    eq.Nombre AS Equipo,
    p.Nombre AS PosicionUnica
FROM Jugador j
JOIN Equipo eq ON j.EquipoID = eq.ID
JOIN JugadorPosicion jp ON j.ID = jp.JugadorID
JOIN Posicion p ON jp.PosicionID = p.ID
WHERE NOT EXISTS (
    SELECT 1
    FROM Jugador j2
    JOIN JugadorPosicion jp2 ON j2.ID = jp2.JugadorID
    WHERE j2.EquipoID = j.EquipoID
      AND j2.ID <> j.ID
      AND jp2.PosicionID = jp.PosicionID
);
