CREATE DATABASE futbol;
USE futbol;
CREATE table competicion (
	nombre VARCHAR(50) primary key,
	num_equipos int NULL
);
CREATE TABLE equipo (
    nombre VARCHAR(50) PRIMARY KEY,
    competicion VARCHAR(50),
    FOREIGN KEY (competicion) REFERENCES competicion(nombre)
);
CREATE TABLE jugador (
    id INT PRIMARY KEY,
    nombre VARCHAR(50),
    equipo VARCHAR(50),
    FOREIGN KEY (equipo) REFERENCES equipo(nombre)
);
CREATE TABLE entrenador (
    id INT PRIMARY KEY,
    nombre VARCHAR(50),
    equipo VARCHAR(50),
    FOREIGN KEY (equipo) REFERENCES equipo(nombre)
);
ALTER TABLE competicion ADD alcance VARCHAR(50);
ALTER TABLE equipo ADD colores VARCHAR(50);
ALTER TABLE jugador CHANGE id dni INT;
ALTER TABLE competicion DROP COLUMN alcance;
ALTER TABLE equipo DROP COLUMN colores;
DROP TABLE entrenador;
CREATE DATABASE futbol_copia;
CREATE TABLE futbol_copia.competicion LIKE futbol.competicion;
CREATE TABLE futbol_copia.equipo LIKE futbol.equipo;
CREATE TABLE futbol_copia.jugador LIKE futbol.jugador;
DROP DATABASE futbol_copia;
